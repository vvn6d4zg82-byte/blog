<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= post.title || '无标题' %> - <%= site_title %></title>
<link rel="stylesheet" href="/css/y2k.css">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
</head>
<body>
<div class="wallpaper-bg">
  <video autoplay muted loop playsinline preload="none" poster="/wallpaper-preview.jpg">
    <source src="<%= settings.wallpaper_url || '/wallpaper.mp4' %>" type="video/mp4">
  </video>
  <div class="wallpaper-overlay" style="opacity:0.6"></div>
</div>
<header style="position:relative;z-index:1;padding:16px 20px;background:rgba(0,0,0,0.3);backdrop-filter:blur(10px);border-bottom:1px solid rgba(180,140,255,0.1)">
  <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:space-between">
    <a href="/" style="color:#b48cff;text-decoration:none;font-size:14px">&larr; 返回</a>
    <% if (auth) { %><a href="/edit/<%= post.id %>" style="color:#ffd700;text-decoration:none;font-size:12px">✎ 编辑</a><% } %>
  </div>
</header>
<main style="position:relative;z-index:1;max-width:900px;margin:0 auto;padding:40px 20px">
  <article style="background:rgba(0,0,0,0.4);backdrop-filter:blur(20px);border:1px solid rgba(180,140,255,0.1);border-radius:16px;padding:40px">
    <div style="margin-bottom:16px">
      <span style="display:inline-block;padding:4px 12px;background:rgba(180,140,255,0.15);border-radius:4px;font-size:10px;color:#b48cff;font-family:'Press Start 2P',monospace"><%= post.post_type || 'article' %></span>
      <span style="color:rgba(255,255,255,0.3);font-size:12px;margin-left:12px"><%= post.date ? (typeof post.date === 'string' ? post.date.slice(0,10) : new Date(post.date).toISOString().slice(0,10)) : '' %></span>
    </div>
    <% if (post.title) { %>
    <h1 style="font-size:28px;font-weight:700;margin-bottom:24px;background:linear-gradient(135deg,#b48cff,#ff6bcd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text"><%= post.title %></h1>
    <% } %>
    <div class="post-content">
      <% if (content && Array.isArray(content)) { %>
        <% content.forEach(function(block) { %>
          <% if (block.type === 'text' || block.type === 'paragraph') { %>
            <p style="line-height:1.8;margin-bottom:16px;color:rgba(255,255,255,0.85)"><%= block.data?.text || block.content || '' %></p>
          <% } else if (block.type === 'header' || block.type === 'heading') { %>
            <h<%= block.data?.level || 2 %> style="margin:24px 0 12px;font-weight:700;color:#b48cff"><%= block.data?.text || block.content || '' %></h<%= block.data?.level || 2 %>>
          <% } else if (block.type === 'image') { %>
            <div style="margin:16px 0;border-radius:12px;overflow:hidden">
              <img src="<%= block.data?.url || block.url || '' %>" alt="<%= block.data?.caption || '' %>" style="width:100%;border-radius:12px">
              <% if (block.data?.caption) { %><p style="text-align:center;color:rgba(255,255,255,0.4);font-size:12px;margin-top:8px"><%= block.data.caption %></p><% } %>
            </div>
          <% } else if (block.type === 'video') { %>
            <div style="margin:16px 0;border-radius:12px;overflow:hidden;background:#000">
              <video controls style="width:100%;max-height:500px" poster="<%= block.data?.poster || '' %>">
                <source src="<%= block.data?.url || block.url || '' %>" type="video/mp4">
              </video>
              <% if (block.data?.caption) { %><p style="text-align:center;color:rgba(255,255,255,0.4);font-size:12px;padding:8px"><%= block.data.caption %></p><% } %>
            </div>
          <% } else if (block.type === 'quote') { %>
            <blockquote style="margin:16px 0;padding:16px 20px;border-left:3px solid #b48cff;background:rgba(180,140,255,0.05);border-radius:0 8px 8px 0;color:rgba(255,255,255,0.7);font-style:italic"><%= block.data?.text || block.content || '' %></blockquote>
          <% } else if (block.type === 'code') { %>
            <pre style="margin:16px 0;padding:16px;background:rgba(0,0,0,0.5);border-radius:8px;overflow-x:auto"><code><%= block.data?.code || block.data?.text || block.content || '' %></code></pre>
          <% } else if (block.type === 'delimiter') { %>
            <hr style="margin:24px 0;border:none;text-align:center;color:rgba(180,140,255,0.3)">✦ ✦ ✦</hr>
          <% } else if (block.type === 'list') { %>
            <% if (block.data?.style === 'ordered') { %>
              <ol style="margin:12px 0;padding-left:24px;line-height:1.8">
              <% (block.data?.items || []).forEach(function(item) { %><li><%= item %></li><% }) %>
              </ol>
            <% } else { %>
              <ul style="margin:12px 0;padding-left:24px;line-height:1.8">
              <% (block.data?.items || []).forEach(function(item) { %><li><%= item %></li><% }) %>
              </ul>
            <% } %>
          <% } %>
        <% }) %>
      <% } else if (typeof content === 'string') { %>
        <p><%= content %></p>
      <% } %>
    </div>
  </article>
</main>
<script src="/js/y2k.js"></script>
</body>
</html>
