<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>我的博客</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="container">
      <h1><a href="/">我的博客</a></h1>
      <nav>
        <a href="/">首页</a>
        <a href="/new">写文章</a>
      </nav>
    </div>
  </header>
  <main class="container">
    <h2>文章列表</h2>
    <% if (posts.length === 0) { %>
      <p class="empty">还没有文章，<a href="/new">写一篇</a>吧！</p>
    <% } %>
    <% posts.forEach(post => { %>
      <article class="post-card">
        <h3><a href="/post/<%= post.id %>"><%= post.title %></a></h3>
        <div class="meta">
          <span class="date"><%= post.date %></span>
        </div>
        <p><%= post.excerpt %>...</p>
        <a href="/post/<%= post.id %>" class="read-more">阅读更多</a>
      </article>
    <% }); %>
  </main>
  <footer>
    <div class="container">
      <p>&copy; 2026 我的博客</p>
    </div>
  </footer>
</body>
</html>
