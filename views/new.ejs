<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>写文章 - <%= settings.site_title || '我的博客' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= settings.theme || 'default' %>">
  <header>
    <div class="container">
      <h1><a href="/"><%= settings.site_title || '我的博客' %></a></h1>
      <% if (settings.site_subtitle) { %><p class="subtitle"><%= settings.site_subtitle %></p><% } %>
      <nav>
        <a href="/">首页</a>
        <a href="/new">写文章</a>
        <a href="/settings">设置</a>
        <a href="/logout">退出</a>
      </nav>
    </div>
  </header>
  <main class="container">
    <h2>写新文章</h2>
    <form action="/new" method="POST" class="post-form">
      <div class="form-group">
        <label for="title">标题</label>
        <input type="text" id="title" name="title" required>
      </div>
      <div class="form-group">
        <label for="content">内容 (支持 Markdown 格式)</label>
        <div class="editor-toolbar">
          <button type="button" class="btn btn-sm" onclick="document.getElementById('fileInput').click()">上传图片</button>
          <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="uploadFile(this)">
          <span id="uploadStatus" class="upload-status"></span>
        </div>
        <textarea id="content" name="content" rows="15" required></textarea>
      </div>
      <button type="submit" class="btn">发布</button>
      <a href="/" class="btn">取消</a>
    </form>
  </main>
  <footer>
    <div class="container">
      <p>&copy; 2026 <%= settings.site_title || '我的博客' %></p>
    </div>
  </footer>
<script>
async function uploadFile(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('uploadStatus');
  status.textContent = '上传中...';
  const fd = new FormData();
  fd.append('file', file);
  try {
    const res = await fetch('/upload', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.url) {
      document.getElementById('content').value += `\n![图片](${data.url})\n`;
      status.textContent = '上传成功!';
    } else {
      status.textContent = '上传失败: ' + (data.error || '未知错误');
    }
  } catch (e) {
    status.textContent = '上传失败: ' + e.message;
  }
  input.value = '';
}
</script>
</body>
</html>
