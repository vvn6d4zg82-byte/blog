<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>设置 - <%= site_title %></title>
<link rel="stylesheet" href="/css/y2k.css">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
</head>
<body>
<header style="position:relative;z-index:10;padding:16px 20px;background:rgba(0,0,0,0.8);backdrop-filter:blur(10px);border-bottom:1px solid rgba(180,140,255,0.1)">
  <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:space-between">
    <a href="/admin" style="color:#b48cff;text-decoration:none;font-size:12px">&larr; 返回管理</a>
    <span style="font-size:12px;color:rgba(255,255,255,0.4);font-family:'Press Start 2P',monospace">✦ 站点设置 ✦</span>
  </div>
</header>
<main style="max-width:900px;margin:0 auto;padding:40px 20px">
  <form method="POST" action="/settings" style="background:rgba(0,0,0,0.3);backdrop-filter:blur(20px);border:1px solid rgba(180,140,255,0.1);border-radius:16px;padding:40px;display:grid;gap:20px">
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">站点名称</label>
      <input name="site_title" value="<%= settings.site_title || '' %>" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none">
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">副标题</label>
      <input name="site_subtitle" value="<%= settings.site_subtitle || '' %>" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none">
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">壁纸视频 URL</label>
      <input name="wallpaper_url" value="<%= settings.wallpaper_url || '' %>" placeholder="/wallpaper.mp4" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none">
      <p style="font-size:11px;color:rgba(255,255,255,0.3);margin-top:4px">支持相对路径 (/wallpaper.mp4) 或完整 URL</p>
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">壁纸遮罩 (0-1)</label>
      <input name="wallpaper_overlay" type="number" step="0.1" min="0" max="1" value="<%= settings.wallpaper_overlay || '0.6' %>" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none">
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">背景音乐 URL</label>
      <input name="music" value="<%= settings.music || '' %>" placeholder="/uploads/music.mp3" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none">
      <p style="font-size:11px;color:rgba(255,255,255,0.3);margin-top:4px">上传音乐文件后自动填入</p>
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">头像 URL</label>
      <input name="avatar" value="<%= settings.avatar || '' %>" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none">
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">关于我</label>
      <textarea name="about" rows="4" style="width:100%;padding:12px 16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;color:#fff;font-size:14px;outline:none;resize:vertical"><%= settings.about || '' %></textarea>
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">上传壁纸视频</label>
      <input type="file" accept="video/mp4,video/webm" onchange="uploadFile(this, 'wallpaper_url')" style="color:#fff;font-size:12px">
    </div>
    <div>
      <label style="display:block;font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;font-family:'Press Start 2P',monospace">上传背景音乐</label>
      <input type="file" accept="audio/*" onchange="uploadFile(this, 'music')" style="color:#fff;font-size:12px">
    </div>
    <button type="submit" style="background:linear-gradient(135deg,rgba(180,140,255,0.3),rgba(255,107,205,0.3));border:1px solid rgba(180,140,255,0.3);border-radius:8px;color:#fff;padding:14px;cursor:pointer;font-size:14px;font-family:'Press Start 2P',monospace;font-size:11px">✦ 保存设置 ✦</button>
  </form>
</main>
<script>
function uploadFile(input, field) {
  const file = input.files[0];
  if (!file) return;
  const formData = new FormData();
  formData.append('file', file);
  fetch('/upload', { method: 'POST', body: formData })
    .then(r => r.json())
    .then(data => {
      if (data.url) {
        const inputs = document.getElementsByName(field);
        if (inputs.length) inputs[0].value = data.url;
        alert('上传成功!');
      }
    })
    .catch(e => alert('上传失败: ' + e.message));
  input.value = '';
}
</script>
</body>
</html>
